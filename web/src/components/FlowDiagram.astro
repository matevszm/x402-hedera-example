---
const nodes = [
  { id: "req", label: "GET /data", sub: "client request" },
  { id: "pay", label: "402 0.01 HBAR", sub: "self-describing" },
  { id: "sign", label: "sign tx", sub: "facilitator pays fee" },
  { id: "ok", label: "200 + data", sub: "settle on Hedera" },
];
---
<div class="relative w-full" data-flow>
  <div class="flex flex-col gap-3">
    {nodes.map((n, i) => (
      <div class="flex flex-col gap-3">
        <div
          data-node={i}
          class="flow-node rounded-xl border border-border bg-surface px-4 py-3 transition-colors duration-300"
        >
          <div class="font-mono text-sm text-text">{n.label}</div>
          <div class="font-mono text-xs text-faint">{n.sub}</div>
        </div>
        {i < nodes.length - 1 && (
          <div class="ml-5 h-5 w-px bg-border" data-edge={i}></div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  import { gsap } from "gsap";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const root = document.querySelector<HTMLElement>("[data-flow]");
  if (root) {
    const nodes = root.querySelectorAll<HTMLElement>("[data-node]");
    const active = "border-accent/70 bg-surface-2";
    if (reduce) {
      nodes.forEach((n) => n.classList.add(...active.split(" ")));
    } else {
      const tl = gsap.timeline({ repeat: -1, repeatDelay: 1.1 });
      nodes.forEach((n) => {
        tl.call(() => {
          nodes.forEach((m) => m.classList.remove(...active.split(" ")));
          n.classList.add(...active.split(" "));
        });
        tl.to({}, { duration: 0.7 });
      });
    }
  }
</script>
