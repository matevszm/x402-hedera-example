---
import { site } from "../data/site.ts";
import Button from "./Button.astro";
import { Icon } from "astro-icon/components";
---
<header class="sticky top-0 z-50 border-b border-border/60 bg-bg/80 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6">
    <a href="#top" class="flex items-center gap-2 font-mono text-sm font-medium focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent rounded-sm">
      <Icon name="ph:lightning-bold" class="size-4 text-accent" />
      x402 / hedera
    </a>
    <div class="hidden items-center gap-7 md:flex">
      {site.nav.map((item) => (
        <a href={item.href} class="text-sm text-muted transition hover:text-text focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent rounded-sm">{item.label}</a>
      ))}
    </div>
    <Button href={site.repoUrl} variant="ghost">GitHub</Button>
  </nav>
</header>
