---
const steps = [
  { k: "01", t: "Request", d: "Your client calls GET /data/:product. No key, no signup." },
  { k: "02", t: "402 reply", d: "The server answers 402 with the exact price, asset, and payTo in the header." },
  { k: "03", t: "Sign", d: "The client signs a Hedera transfer. The facilitator pays the network fee." },
  { k: "04", t: "200 + data", d: "Retry with the payment. Payment settles on Hedera, data returns." },
];
---
<section id="how" class="border-t border-border/60">
  <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
    <h2 class="max-w-[18ch] text-3xl font-semibold tracking-tighter md:text-4xl">
      One request, one payment, one response.
    </h2>
    <div class="mt-12 grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-4">
      {steps.map((s) => (
        <div class="reveal bg-bg p-6">
          <div class="font-mono text-sm text-accent">{s.k}</div>
          <div class="mt-3 text-lg font-medium">{s.t}</div>
          <p class="mt-2 text-sm leading-relaxed text-muted">{s.d}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm text-faint">The facilitator (blocky402) covers the network fee. You pay only the data price.</p>
  </div>
</section>
