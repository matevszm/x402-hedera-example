---
import { Icon } from "astro-icon/components";
const items = [
  "This is a testnet demo. Data is deterministic mock, not real market data.",
  "Settlement runs after the handler returns 200. A verify-pass / settle-fail means data was delivered without payment landing. Accepted for this zero-value demo.",
];
---
<section class="border-t border-border/60 reveal">
  <div class="mx-auto max-w-7xl px-6 py-20 md:py-28">
    <div class="rounded-xl border border-border bg-surface p-8">
      <div class="flex items-center gap-2">
        <Icon name="ph:warning-bold" class="size-5 text-accent" />
        <h2 class="text-xl font-semibold tracking-tight">Demo limitations</h2>
      </div>
      <ul class="mt-5 flex flex-col gap-3">
        {items.map((t) => (
          <li class="flex gap-3 text-sm leading-relaxed text-muted">
            <span class="mt-2 size-1 shrink-0 rounded-full bg-faint"></span>
            {t}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
